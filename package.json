{
  "name": "ascension-armory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "validate:catalog": "tsx tooling/validation/validate-catalog.ts",
    "shard:catalog": "tsx tooling/catalog/shard-published-catalog.ts",
    "check": "npm run typecheck && npm run lint && npm test && npm run validate:catalog",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "ingest:items": "tsx tooling/importers/ingest-items.ts",
    "extract:client-items": "uv run --with mpyq python tooling/extraction/extract-client-items.py",
    "extract:realm-cache": "python3 tooling/extraction/extract-realm-item-cache.py",
    "ingest:client-items": "tsx tooling/importers/import-client-items.ts",
    "ingest:realm-cache": "tsx tooling/importers/import-realm-item-cache.ts",
    "ingest:addon-catalog": "tsx tooling/importers/import-addon-catalog.ts",
    "ingest:addon-scaling": "tsx tooling/importers/import-addon-scaling.ts",
    "sync:coa-classes": "node tooling/enrichment/sync-coa-classes.mjs",
    "sync:sidekick-gear": "tsx tooling/enrichment/sync-sidekick-gear.ts",
    "import:worldforged": "tsx tooling/importers/import-lootcollector-worldforged.ts",
    "extract:atlasloot": "tsx tooling/extraction/extract-atlasloot-coa-items.ts",
    "extract:coa-enchants": "uv run --with mpyq python tooling/extraction/extract-coa-enchants.py",
    "generate:dungeon-variants": "tsx tooling/enrichment/generate-dungeon-variants.ts",
    "generate:scaling-candidates": "tsx tooling/enrichment/generate-scaling-candidates.ts",
    "generate:addon-candidates": "tsx tooling/enrichment/generate-addon-candidates.ts",
    "generate:worldforged-upgrades": "tsx tooling/enrichment/generate-worldforged-upgrades.ts",
    "export:catalog": "tsx tooling/exporters/export-static-catalog.ts",
    "publish:catalog": "npm run export:catalog && npm run validate:catalog",
    "publish:catalog-existing": "npm run shard:catalog && npm run validate:catalog"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "6.19.3",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
