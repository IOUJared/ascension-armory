generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EquipmentSlot {
  HEAD
  NECK
  SHOULDERS
  BACK
  CHEST
  WRISTS
  HANDS
  WAIST
  LEGS
  FEET
  FINGER_1
  FINGER_2
  TRINKET_1
  TRINKET_2
  MAIN_HAND
  OFF_HAND
  RANGED
}

enum ItemQuality {
  POOR
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  ARTIFACT
  HEIRLOOM
}

enum SocketColor {
  META
  RED
  YELLOW
  BLUE
  PRISMATIC
  ASCENSION
}

enum EffectKind {
  EQUIP
  USE
  PROC
  SET_BONUS
  ASCENSION
}

enum StatSource {
  BASE
  SOCKET_BONUS
  GEM
  MYSTIC_ENCHANT
  CUSTOM_EFFECT
}

model Item {
  id               BigInt        @id
  name             String
  slug             String?
  quality          ItemQuality
  itemLevel        Int
  requiredLevel    Int            @default(1)
  slot             EquipmentSlot?
  inventoryType    Int?
  armorType        String?
  armor            Float          @default(0)
  weaponMinDamage  Float?
  weaponMaxDamage  Float?
  weaponSpeed      Float?
  weaponDps        Float?
  icon             String?
  sourceUrl        String
  sourceRealm      String          @default("CONQUEST_OF_AZEROTH")
  rawTooltipHtml   String
  rawPayload       Json            @db.JsonB
  contentHash      String
  sourceUpdatedAt  DateTime?
  ingestedAt       DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  stats            ItemStat[]
  sockets          ItemSocket[]
  effects          ItemEffect[]
  equippedIn       EquippedItem[]

  @@index([slot, requiredLevel, itemLevel])
  @@index([name])
}

model StatDefinition {
  key          String    @id
  label        String
  unit         String    @default("flat")
  category     String
  description  String?
  isCustom     Boolean   @default(false)
  isWeightable Boolean   @default(true)
  stats        ItemStat[]
  weights      ProfileStatWeight[]
  gemStats     GemStat[]
  enchantStats MysticEnchantStat[]
}

model ItemStat {
  id       BigInt         @id @default(autoincrement())
  itemId   BigInt
  statKey  String
  value    Float
  source   StatSource     @default(BASE)
  metadata Json?          @db.JsonB
  item     Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)
  stat     StatDefinition @relation(fields: [statKey], references: [key])

  @@unique([itemId, statKey, source])
  @@index([statKey, value])
}

model ItemSocket {
  id       BigInt      @id @default(autoincrement())
  itemId   BigInt
  position Int
  color    SocketColor
  item     Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, position])
}

model ItemEffect {
  id           BigInt     @id @default(autoincrement())
  itemId       BigInt
  kind         EffectKind
  description  String
  spellId      BigInt?
  coefficient  Float?
  procChance   Float?
  cooldownMs   Int?
  customData   Json?      @db.JsonB
  item         Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, kind])
}

model Gem {
  id            BigInt      @id
  name          String
  quality       ItemQuality
  color         SocketColor
  requiredLevel Int         @default(1)
  icon          String?
  customData    Json?       @db.JsonB
  stats         GemStat[]
  equipped      EquippedGem[]
}

model GemStat {
  gemId   BigInt
  statKey String
  value   Float
  gem     Gem            @relation(fields: [gemId], references: [id], onDelete: Cascade)
  stat    StatDefinition @relation(fields: [statKey], references: [key])

  @@id([gemId, statKey])
}

model MysticEnchant {
  id             BigInt    @id
  name           String
  description    String
  tier           Int       @default(1)
  requiredLevel  Int       @default(1)
  allowedSlots   EquipmentSlot[]
  stackingGroup  String?
  maxStacks      Int       @default(1)
  scalingFormula Json?     @db.JsonB
  customData     Json?     @db.JsonB
  stats          MysticEnchantStat[]
  equipped       EquippedMysticEnchant[]
}

model MysticEnchantStat {
  mysticEnchantId BigInt
  statKey         String
  value            Float
  perLevel         Float    @default(0)
  hybridRule       Json?    @db.JsonB
  mysticEnchant    MysticEnchant @relation(fields: [mysticEnchantId], references: [id], onDelete: Cascade)
  stat             StatDefinition @relation(fields: [statKey], references: [key])

  @@id([mysticEnchantId, statKey])
}

model User {
  id        String             @id @default(cuid())
  email     String?            @unique
  name      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  profiles  CharacterProfile[]
}

model CharacterProfile {
  id            String              @id @default(cuid())
  userId        String?
  name          String
  level         Int                 @default(60)
  realm         String              @default("CONQUEST_OF_AZEROTH")
  buildNotes    String?
  hybridScaling Json?               @db.JsonB
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  user          User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  weights       ProfileStatWeight[]
  loadouts      Loadout[]

  @@index([userId])
}

model ProfileStatWeight {
  profileId String
  statKey   String
  weight    Float
  cap       Float?
  softCap   Float?
  profile   CharacterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  stat      StatDefinition   @relation(fields: [statKey], references: [key])

  @@id([profileId, statKey])
}

model Loadout {
  id        String           @id @default(cuid())
  profileId String
  name      String
  isActive  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  profile   CharacterProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items     EquippedItem[]

  @@index([profileId, isActive])
}

model EquippedItem {
  id           String       @id @default(cuid())
  loadoutId    String
  itemId       BigInt
  slot         EquipmentSlot
  randomSuffix Json?        @db.JsonB
  customStats  Json?        @db.JsonB
  loadout      Loadout      @relation(fields: [loadoutId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id])
  gems         EquippedGem[]
  enchants     EquippedMysticEnchant[]

  @@unique([loadoutId, slot])
  @@index([itemId])
}

model EquippedGem {
  equippedItemId String
  socketPosition Int
  gemId          BigInt
  equippedItem   EquippedItem @relation(fields: [equippedItemId], references: [id], onDelete: Cascade)
  gem            Gem          @relation(fields: [gemId], references: [id])

  @@id([equippedItemId, socketPosition])
}

model EquippedMysticEnchant {
  equippedItemId  String
  mysticEnchantId BigInt
  rank             Int            @default(1)
  equippedItem     EquippedItem   @relation(fields: [equippedItemId], references: [id], onDelete: Cascade)
  mysticEnchant    MysticEnchant  @relation(fields: [mysticEnchantId], references: [id])

  @@id([equippedItemId, mysticEnchantId])
}
